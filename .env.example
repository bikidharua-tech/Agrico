# Copy this file to `.env` and fill in your real values.

APP_NAME=Agrico
APP_BASE_URL=https://your-app.onrender.com

DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=agrico
DB_USER=your-mysql-user
DB_PASS=your-mysql-password

PYTHON_API_URL=http://127.0.0.1:8001

PLANT_ID_ENABLED=0
PLANT_ID_API_URL=https://plant.id/api/v3
PLANT_ID_API_KEY=
PLANT_ID_MODEL=latest

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

WEATHER_DEFAULT_CITY=

GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.onrender.com/oauth_google_callback.php

FACEBOOK_OAUTH_APP_ID=your-facebook-app-id
FACEBOOK_OAUTH_APP_SECRET=your-facebook-app-secret
FACEBOOK_OAUTH_REDIRECT_URI=https://your-app.onrender.com/oauth_facebook_callback.php
